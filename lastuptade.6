
// Suffix Tree Kodu

#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#define toplamkarakter 256


struct Suffix_kok {

	//bir koku baska bir koke baglayan degisken
	struct Suffix_kok *suffixbaglac;

    struct Suffix_kok *eksuffix[toplamkarakter];

	//suffix index ile kok mu yaprak mi oldugu belirtildi
	int suffixIndex;

    //start ve end degiskenleri ile indexler belirtildi
    int bas;
	int *bitis;

};


char girdi[100]; //girdi stringi tutan degisken

typedef struct Suffix_kok kok;

kok *baskok = NULL; //kok dugumunu gosteren pointer

//sonyenidugum yeni olusturulup henuz suffixlink i olusturulmayan dugumler icin kullanýlacak.
kok *sonyenidugum = NULL;
//aktifdugum degiskeni ile anlik aktif dugum pointer ile kullanildi
kok *aktifdugum = NULL;
//dugum sayisini sayan count degiskeni
int count=0;

//aktif uzunluk  dugumdeki anlik konumumuzu kullanmak icin kullanildi
int aktifUzunluk = 0;

/*aktifKenar  inputtaki karakterin indexini temsil ediyor.*/
int aktifKenar = -1;


// KalanSuffixSayisi suffix eklerken ekleme yapmamiz gereken suffix sayisini belirtir.
int KalanSuffixSayisi = 0;

int size = -1; //inputun uzunlugunu tutan degisken

int leafEnd = -1;

int *rootEnd = NULL;

int *splitEnd = NULL;



                                      //YENI DUGUM ACAN FONKSIYON
kok *YeniDugumAc(int bas, int *bitis)
{

	kok *node =(kok*) malloc(sizeof(kok));
	count++;
	int i;
	for (i = 0; i < toplamkarakter; i++)
		node->eksuffix[i] = NULL;

	/*kok dugumu icin suffixbaglac 0 olarak tanimlanacak
	ic kokler icin, suufixbaglac kok dugum olarak secilecek
	 */
	node->suffixbaglac = baskok;
	node->bas = bas;
	node->bitis = bitis;

	//suffixIndex her zaman basta -1 olarak tanimlanacak ve	asil suffix index degeri ilerde yapraklar icin de tanimlanacak

	node->suffixIndex = -1;

	return node;
}
                                            //KENAR UZUNLUGU BULAN FONKSIYON

int KenarUzunlugu(kok *n) {

	return *(n->bitis) - (n->bas) + 1;

}

                                                    //DOLASMA FONKSIYONU
int AsagiDogruInme(kok *currNode)
{
	if (aktifUzunluk >= KenarUzunlugu(currNode))
	{
		aktifKenar =
		(int)girdi[aktifKenar+KenarUzunlugu(currNode)]-(int)' ';
		aktifUzunluk -= KenarUzunlugu(currNode);
		aktifdugum = currNode;
		return 1;
	}
	return 0;
}

                                     //SUFFIX EKLEYEN FONKSIYON
void agac_ekle(int pos)
{
	//1. Ekleme kuralina gore ekleme yapma
	leafEnd = pos;

	KalanSuffixSayisi++;

	sonyenidugum = NULL;

	//Eklenemsi gereken butun suffixleri agaca ekle
	while(KalanSuffixSayisi > 0) {


		if (aktifUzunluk == 0) {
			aktifKenar = (int)girdi[pos]-(int)' ';
		}

		// Eger aktifkKenar ile baslayan bi dugum aktifdugumde yoksa

		if (aktifdugum->eksuffix[aktifKenar] == NULL)
		{
			//2.ekleme kurali yeni yaprak olusturma
			aktifdugum->eksuffix[aktifKenar] =	YeniDugumAc(pos, &leafEnd);

			//Yeni olusan ic dugumun suffixbaglacini koyma
			if (sonyenidugum != NULL)
			{
				sonyenidugum->suffixbaglac = aktifdugum;
				sonyenidugum = NULL;
			}
		}
		// Eger aktifkKenar ile baslayan bi dugum aktifdugumde varsa

        else
		{
			// Yeni Dugume gecis yap
			kok *next = aktifdugum->eksuffix[aktifKenar];
			//kenarda asagiyurume yap
			if (AsagiDogruInme(next))
			{
				//yeni bir aktifdugumden basla
				continue;
			}

			// Ekleme 3.kurali (karakter zaten islem yapilan dugumde bulunuyorsa)

			if (girdi[next->bas + aktifUzunluk] == girdi[pos])

			{
				//Yeni acilan dugumun suffixlinkini yaratma
				if(sonyenidugum != NULL && aktifdugum != baskok)
				{
					sonyenidugum->suffixbaglac = aktifdugum;
					sonyenidugum = NULL;
				}


				aktifUzunluk++;

				break;
			}

			//Eger islem yaptigimiz kenarda yeni yaprak acmamiz gerekiyorsa burada olacagiz
			//ve 2.ekleme kuralina gore ekleme yapacagiz

			splitEnd = (int*) malloc(sizeof(int));

			*splitEnd = next->bas + aktifUzunluk - 1;

			//yeni ic dugum

			kok *split = YeniDugumAc(next->bas, splitEnd);

			aktifdugum->eksuffix[aktifKenar] = split;

			//yeni ic dugume yeni yaprak ekleme
			split->eksuffix[(int)girdi[pos]-(int)' '] =YeniDugumAc(pos, &leafEnd);

			next->bas += aktifUzunluk;

			split->eksuffix[aktifKenar] = next;

			/*yeni olusturdugumuz internal node icin seuffex linkini olusturma*/

			if (sonyenidugum != NULL)
			{
				sonyenidugum->suffixbaglac = split;
			}


			sonyenidugum = split;
		}

		//bir suffic basariyla eklendi kalan suffix sayisini azalt
		KalanSuffixSayisi--;

		if (aktifdugum == baskok && aktifUzunluk > 0)
		{

			aktifUzunluk--;
			aktifKenar = (int)girdi[pos -KalanSuffixSayisi + 1]-(int)' ';

		}


		else if (aktifdugum != baskok)
		{
			aktifdugum = aktifdugum->suffixbaglac;
		}

	}

}
