///deneme fonksiyonlari

int edgeLengthf(kok *n) {
    if(n == baskok)
        return 0;
    return *(n->bitis) - (n->bas) + 1;
}

            //2.ister baslangici
int traverseEdge(char *str, int idx, int bas, int bitis)
{
    int k = 0;
    //Traverse the edge with character by character matching
    for(k=bas; k<=bitis && str[idx] != '\0'; k++, idx++)
    {
        if(girdi[k] != str[idx])
            return -1;  // mo match
    }
    if(str[idx] == '\0')
        return 1;  // match
    return 0;  // more characters yet to match
}

int doTraversalToCountLeaf(kok *n)
{
    if(n == NULL)
        return 0;
    if(n->suffixIndex > -1)
    {
        printf("\nBu pozisyonda bulundu: %d", n->suffixIndex);
        return 1;
    }
    int counter = 0;
    int i = 0;
    for (i = 0; i < toplamkarakter; i++)
    {
        if(n->eksuffix[i] != NULL)
        {
            counter += doTraversalToCountLeaf(n->eksuffix[i]);
        }
    }
    return counter;
}

int countLeaf(kok *n)
{
    if(n == NULL)
        return 0;
    return doTraversalToCountLeaf(n);
}

int doTraversal(kok *n, char* str, int idx)
{
    if(n == NULL)
    {
        return -1; // no match
    }
    int res = -1;
    //If node n is not root node, then traverse edge
    //from node n's parent to node n.
    if(n->bas != -1)
    {
        res = traverseEdge(str, idx, n->bas, *(n->bitis));
        if(res == -1)  //no match
            return -1;
        if(res == 1) //match
        {
            if(n->suffixIndex > -1)
                printf("\nkatar kac defa geciyor: 1 ve pozisyonu: %d",n->suffixIndex);
            else
                printf("\nkatar sayaci: %d", countLeaf(n));
            return 1;
        }
    }
    //Get the character index to search
    idx = idx + edgeLengthf(n);
    //If there is an edge from node n going out
    //with current character str[idx], traverse that edge
    if(n->eksuffix[(int)str[idx]-(int)' '] != NULL)
        return doTraversal(n->eksuffix[(int)str[idx]-(int)' '], str, idx);
    else
        return -1;  // no match
}

void checkForSubString(char* str)
{
    int res = doTraversal(baskok, str, 0);
    if(res == 1)
        printf("\nGirdi <%s> bir altdizedir.\n", str);
    else
        printf("\nGirdi <%s> bir altdize degildir.\n", str);
}
