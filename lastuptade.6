void gecis_yap_2(kok *n, int Etiket_uzunluk, int* maxUzunluk,int* subs_baslangic_index)
{

    if(n == NULL)
    {
        return;
    }

    int i=0;


    //ic dugum kontrolu
    if(n->suffixIndex == -1)
    {
        for (i = 0; i < 256; i++)
        {
            if(n->eksuffix[i] != NULL)
            {
                gecis_yap_2(n->eksuffix[i], Etiket_uzunluk +KenarUzunlugu(n->eksuffix[i]), maxUzunluk,subs_baslangic_index);
            }
        }
    }
    else if(n->suffixIndex > -1 &&
                (*maxUzunluk < Etiket_uzunluk - KenarUzunlugu(n)))
    {
        *maxUzunluk = Etiket_uzunluk - KenarUzunlugu(n);
        *subs_baslangic_index = n->suffixIndex;
    }
}


