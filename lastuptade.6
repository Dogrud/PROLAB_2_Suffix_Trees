int KenarUzunOlcme(kok *n) {

    if(n == baskok)
        return 0;

    return *(n->bitis) - (n->bas) + 1;

}

                                                            //2.ister baslangici

int yaprak_gecisi_yap(char *str, int idx, int bas, int bitis)
{
    int k = 0;


    //Karakter eslesmesine gore ilerle

    for(k=bas; k<=bitis && str[idx] != '\0'; k++, idx++)
    {
        if(girdi[k] != str[idx])
            return -1;  //eslesme yok
    }

    if(str[idx] == '\0')
        return 1;  // eslesti

    return 0;
}

//yaprak sayimi icin gecis yap

int yaprak_sayimi_gecis(kok *n)
{

    if(n == NULL)
        return 0;

    if(n->suffixIndex > -1)
    {
        printf("\nBu pozisyonda bulundu: %d", n->suffixIndex);
        return 1;
    }

    int counter = 0;

    int i = 0;

    for (i = 0; i < toplamkarakter; i++)
    {
        if(n->eksuffix[i] != NULL)
        {
            counter += yaprak_sayimi_gecis(n->eksuffix[i]);
        }
    }
    return counter;
}

//Yaprak sayaci
int yaprak_sayac(kok *y)
{
    if(y == NULL)
        return 0;
    return yaprak_sayimi_gecis(y);
}


int Gecis_yap(kok *n, char* str, int idx)
{
    //suffix kok kontrolu
    if(n == NULL)
    {
        return -1;
    }

    int res = -1;
    //eger n kok degilse bi onceki dugume gecis yap
    if(n->bas != -1)
    {
        res = yaprak_gecisi_yap(str, idx, n->bas, *(n->bitis));
        if(res == -1)
            return -1; //suffix kontrolu olumsuz
        if(res == 1)    // suffix kontrolu olumlu
        {
            if(n->suffixIndex > -1)
                printf("\nkatar kac defa geciyor: 1 ve pozisyonu: %d",n->suffixIndex);
            else
                printf("\nkatar sayaci: %d", yaprak_sayac(n));
            return 1;
        }
    }
    //arama icin karakter indexi al
    idx = idx + KenarUzunOlcme(n);
    //eger n den karakterle ilgili cikisolan bir kenar var ise ona gecis yap

    if(n->eksuffix[(int)str[idx]-(int)' '] != NULL)
        return Gecis_yap(n->eksuffix[(int)str[idx]-(int)' '], str, idx);

    else
        return -1;  // no match

}

void Katar_Kontrol(char* kontrol_girdi)
{
    int kontroller = Gecis_yap(baskok, kontrol_girdi, 0);

    if(kontroller == 1)
        printf("\nGirdi <%s> bir altdizedir.\n", kontrol_girdi);

    else
        printf("\nGirdi <%s> bir altdize degildir.\n", kontrol_girdi);
}
