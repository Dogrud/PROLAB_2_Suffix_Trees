                                      // suffix_index_koyan_fonksiyon
void suffix_indeksleri_yeslestir(kok *n, int labelHeight)
{

        if (n == NULL) return;

        //kok kontrolu

	if (n->bas != -1)
	{
		//karakterleri yazdir
		print(n->bas, *(n->bitis));

	}
	int i;

    int leaf = 1;

	for (i = 0; i < toplamkarakter; i++)
	{

		if (n->eksuffix[i] != NULL)
		{
            if (leaf == 1 && n->bas!= -1)
				printf(" [%d]\n", n->suffixIndex);

			//aktif nod kok degil cunkku yapraklari var

			leaf = 0;

			suffix_indeksleri_yeslestir(n->eksuffix[i],
				labelHeight + KenarUzunlugu(n->eksuffix[i]));
		}
	}
	if (leaf == 1)
	{
		n->suffixIndex = size - labelHeight;
		printf(" [%d]\n", n->suffixIndex);
	}
}


                                                        //free suffix fonksiyonu
void Alan_Bosaltma(kok *n)
{
	if (n == NULL)
		printf("alan bosaltilamadi");

    int i;

	for (i = 0; i < toplamkarakter; i++)
	{
		if (n->eksuffix[i] != NULL)
		{
			Alan_Bosaltma(n->eksuffix[i]);
		}
	}

	if (n->suffixIndex == -1)

		free(n->bitis);

	free(n);
}

//suffix olusturan ana fonksiyon burası burada yapraklarimiza >= 0 suffixindex degerini veriyoruz
//Yaprak olmayan koseler icin ise -1 degerini veriyoruz


                                           //suffix olusturan fonksiyon
void suffix_olustur()
{
	size = strlen(girdi);
	int i;
	rootEnd = (int*) malloc(sizeof(int));
	*rootEnd = - 1;

	/*Root is a special node with start and end indices as -1,
	as it has no parent from where an edge comes to root*/
	baskok = YeniDugumAc(-1, rootEnd);

	aktifdugum = baskok; //First aktifdugum will be root
	for (i=0; i<size; i++)
		agac_ekle(i);
	int labelHeight = 0;
	suffix_indeksleri_yeslestir(baskok, labelHeight);


}
