}

//Print the suffix tree as well along with setting suffix index
//So tree will be printed in DFS manner
//Each edge along with it's suffix index will be printed


                                        //!suffix_index_koyan_fonksiyon
void setSuffixIndexByDFS(kok *n, int labelHeight)
{
	if (n == NULL) return;

	if (n->bas != -1) //A non-root node
	{
		//Print the label on edge from parent to current node
		print(n->bas, *(n->bitis));
	}
	int leaf = 1;
	int i;
	for (i = 0; i < toplamkarakter; i++)
	{
		if (n->eksuffix[i] != NULL)
		{
			if (leaf == 1 && n->bas!= -1)
				printf(" [%d]\n", n->suffixIndex);

			//Current node is not a leaf as it has outgoing
			//edges from it.
			leaf = 0;
			setSuffixIndexByDFS(n->eksuffix[i],
				labelHeight + KenarUzunlugu(n->eksuffix[i]));
		}
	}
	if (leaf == 1)
	{
		n->suffixIndex = size - labelHeight;
		printf(" [%d]\n", n->suffixIndex);
	}
}
                                            //free suffix fonksiyonu
void freeSuffixTreeByPostOrder(kok *n)
{
	if (n == NULL)
		return;
	int i;
	for (i = 0; i < toplamkarakter; i++)
	{
		if (n->eksuffix[i] != NULL)
		{
			freeSuffixTreeByPostOrder(n->eksuffix[i]);
		}
	}
	if (n->suffixIndex == -1)
		free(n->bitis);
	free(n);
}

/*Build the suffix tree and print the edge labels along with
suffixIndex. suffixIndex for leaf edges will be >= 0 and
for non-leaf edges will be -1*/
                                                //suffix olusturan fonksiyon
void buildSuffixTree()
{
	size = strlen(girdi);
	int i;
	rootEnd = (int*) malloc(sizeof(int));
	*rootEnd = - 1;

	/*Root is a special node with start and end indices as -1,
	as it has no parent from where an edge comes to root*/
	baskok = YeniDugumAc(-1, rootEnd);

	aktifdugum = baskok; //First aktifdugum will be root
	for (i=0; i<size; i++)
		extendSuffixTree(i);
	int labelHeight = 0;
	setSuffixIndexByDFS(baskok, labelHeight);


}
