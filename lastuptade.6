                                    //!3.ister baslangici
void doTraversal2(kok *n, int labelHeight, int* maxHeight,int* substringStartIndex)
{
    if(n == NULL)
    {
        return;
    }
    int i=0;
    if(n->suffixIndex == -1) //If it is internal node
    {
        for (i = 0; i < 256; i++)
        {
            if(n->eksuffix[i] != NULL)
            {
                doTraversal2(n->eksuffix[i], labelHeight +
                                KenarUzunlugu(n->eksuffix[i]), maxHeight,
                                 substringStartIndex);
            }
        }
    }
    else if(n->suffixIndex > -1 &&
                (*maxHeight < labelHeight - KenarUzunlugu(n)))
    {
        *maxHeight = labelHeight - KenarUzunlugu(n);
        *substringStartIndex = n->suffixIndex;
    }
}


void getLongestRepeatedSubstring()
{
    int maxHeight = 0;
    int substringStartIndex = 0;
    doTraversal2(baskok, 0, &maxHeight, &substringStartIndex);
//    printf("maxHeight %d, substringStartIndex %d\n", maxHeight,
//           substringStartIndex);
    printf("En cok tekrar eden substring %s : ", girdi);
    int k;
    for (k=0; k<maxHeight; k++)
        printf("%c", girdi[k + substringStartIndex]);
    if(k == 0)
        printf("Tekrar eden substring bulunamadi...");
    printf("\n");
}

